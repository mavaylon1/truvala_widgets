# Google Maps — used for Street View embed and Places API (Nearby Search, Text Search)
# Enable "Maps Embed API" and "Places API (New)" on this key in Google Cloud Console
VITE_GOOGLE_MAPS_EMBED_KEY=

# OpenAI — used by the Concierge widget for chat completions
# The key is exposed in the browser bundle. For production, proxy through a backend.
VITE_OPENAI_API_KEY=
